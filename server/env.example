PORT=5001
JWT_SECRET=your_jwt_secret_key_here
NODE_ENV=development

# Email notifications (optional) — uses Nodemailer with Gmail SMTP.
# If EMAIL_USER or EMAIL_PASS is unset, game result emails are skipped (no error).
# EMAIL_PASS must be a Gmail App Password, not your account password.
# https://myaccount.google.com/apppasswords
EMAIL_USER=
EMAIL_PASS=
