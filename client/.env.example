# Optional: secret segment for the hidden player-email page.
# URL: https://your-domain.com/email-updates/<this-value>
# Must match on Vercel: Project → Settings → Environment Variables → REACT_APP_EMAIL_UPDATE_TOKEN
# Generate e.g. openssl rand -hex 24
REACT_APP_EMAIL_UPDATE_TOKEN=

# Optional: override API base (default on localhost is http://localhost:5001/api)
# REACT_APP_API_URL=https://your-domain.com/api
